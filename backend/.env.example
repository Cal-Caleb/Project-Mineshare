# Copy this to .env and fill in your values.
# DO NOT commit .env to git.

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/modserver

# Discord OAuth2 + Bot
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_ROLE1_ID=
DISCORD_ROLE2_ID=
DISCORD_REDIRECT_URI=http://localhost:8000/api/auth/callback

# JWT
JWT_SECRET=change-me-in-production

# Redis
REDIS_URL=redis://localhost:6379/0

# CurseForge
CURSEFORGE_API_KEY=

# Minecraft Server
SERVER_PATH=/opt/minecraft/server
BACKUP_PATH=/opt/minecraft/backups
RCON_HOST=localhost
RCON_PORT=25575
RCON_PASSWORD=

# ClamAV
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# Uploads
UPLOAD_DIR=/opt/minecraft/uploads
QUARANTINE_DIR=/opt/minecraft/quarantine

# Voting
VOTE_DURATION_HOURS=12

# Discord notification channels (channel IDs)
CHANNEL_MOD_PROPOSALS=
CHANNEL_MOD_UPLOADS=
CHANNEL_SERVER_STATUS=

# Frontend
FRONTEND_URL=http://localhost:3000
